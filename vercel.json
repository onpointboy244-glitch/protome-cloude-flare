{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/favicon.svg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|assets/|favicon\\.|robots\\.|.*\\.[a-z]+$).+)",
      "destination": "/api/og?username=$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
